{
  "name": "pr-review-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "build": "pnpm -r run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "worker": "pnpm --filter orchestrator worker",
    "worker:watch": "pnpm --filter orchestrator worker:watch",
    "poller": "pnpm --filter orchestrator poller",
    "poller:watch": "pnpm --filter orchestrator poller:watch",
    "signal-pr": "pnpm --filter orchestrator signal-pr",
    "smoke": "pnpm --filter orchestrator smoke",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy"
  },
  "devDependencies": {
    "convex": "^1.34.1",
    "prettier": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "protobufjs"
    ]
  }
}
