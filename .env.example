# Temporal
TEMPORAL_ADDRESS=temporal.j5:7233
TEMPORAL_NAMESPACE=pr-review
TEMPORAL_TASK_QUEUE=pr-review-orchestrator

# Poller
POLL_INTERVAL_SECONDS=60
GITHUB_ALLOWED_REPOS=
GITHUB_ALLOWED_AUTHOR=

# GitHub
GITHUB_TOKEN=github_pat_replace_me
GITHUB_API_URL=https://api.github.com
GIT_USER_NAME=PR Review Bot
GIT_USER_EMAIL=pr-review-bot@example.com

# Convex
CONVEX_URL=https://your-deployment.convex.cloud

# Linear
LINEAR_API_KEY=lin_api_replace_me
LINEAR_TEAM_ID=replace_me
LINEAR_DEFAULT_PROJECT_ID=replace_me

# Vercel
VERCEL_TOKEN=

# AI Runtime
AI_DEFAULT_PROVIDER=codex
CODEX_MODEL=gpt-5.3-codex
CODEX_ALLOW_NPX=true
CODEX_HOME_DIR=/absolute/path/to/codex-home
CLAUDE_CODE_MODEL=sonnet

# Runtime
LOG_LEVEL=info
WORKSPACE_ROOT=/absolute/path/to/pr-workspaces
REVIEWER_PACKS_REPO_PATH=/absolute/path/to/reviewer-packs
REVIEWER_PACKS_REPO_URL=https://github.com/your-org/reviewer-packs.git
